{
  "name": "newt",
  "version": "1.1.0",
  "description": "Comprehensive AI development assistant plugin for Claude Code, Windsurf, and Cursor",
  "main": "index.js",
  "scripts": {
    "validate": "node scripts/validate-plugin.js",
    "validate:config": "node scripts/config-validator.js",
    "mcp:server": "node mcp/server.mjs",
    "install:hooks": "bash scripts/install-hooks.sh",
    "refresh:plugin": "node scripts/refresh-plugin.js",
    "refresh:plugin:watch": "node scripts/refresh-plugin.js --watch",
    "refresh:plugin:windsurf": "powershell -ExecutionPolicy Bypass -File scripts/refresh-plugin.ps1 --target windsurf",
    "refresh:plugin:cursor": "powershell -ExecutionPolicy Bypass -File scripts/refresh-plugin.ps1 --target cursor",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "echo \"E2E tests not yet implemented\"",
    "lsp:server": "node lsp/index.js",
    "lsp:server:debug": "node lsp/index.js --debug",
    "lsp:test": "jest lsp/tests/",
    "lsp:test:watch": "jest lsp/tests/ --watch"
  },
  "keywords": [
    "claude-code",
    "windsurf",
    "cursor",
    "code-review",
    "ai-assistant",
    "architecture",
    "security",
    "performance",
    "brainstorming",
    "pr-review"
  ],
  "author": "Claude Code Plugin Developer",
  "license": "MIT",
  "devDependencies": {
    "js-yaml": "^4.1.0",
    "vscode-languageserver": "^9.0.0",
    "vscode-languageserver-protocol": "^3.17.0",
    "vscode-languageserver-textdocument": "^1.0.0",
    "jest": "^29.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.5.3",
    "yargs": "^17.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
